{
  "name": "gxcode",
  "version": "1.3.3",
  "main": "main.js",
  "description": "L'IDE AI-Nativo professionale per lo sviluppo software moderno. Powered by Cloud-GX.",
  "author": "Giovanni Faggiano (Cloud-GX)",
  "homepage": "https://cloud-gx.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kyriga-CGX/GXCode.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.27",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0"
  },
  "build": {
    "appId": "io.gxcode.ide",
    "productName": "GXCode",
    "copyright": "Copyright © 2026 Kyriga",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "APP/**/*",
      "package.json"
    ],
    "win": {
      "icon": "APP/assets/logo.png",
      "target": [
        "nsis"
      ],
      "publish": [
        "github"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeader": "APP/assets/installer_header.bmp",
      "installerSidebar": "APP/assets/installer_sidebar.bmp",
      "allowElevation": true,
      "perMachine": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "GXCode"
    },
    "publish": {
      "provider": "github",
      "owner": "Kyriga-CGX",
      "repo": "GXCode"
    }
  }
}
